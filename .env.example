# ============================================================
#   GenAI-Driven Nifty50 & Bank Nifty Market Predictor
#   Environment Configuration
# ============================================================

# OpenAI API Key (Required)
OPENAI_API_KEY=your_openai_api_key_here

# Model Selection
OPENAI_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# News API (Optional - for enhanced news retrieval)
NEWS_API_KEY=your_newsapi_key_here

# Vector Store Settings
CHROMA_PERSIST_DIR=./data/chroma_db
FAISS_INDEX_PATH=./data/faiss_index

# Prediction Settings
PREDICTION_HORIZON=5          # Days ahead to predict
LOOKBACK_PERIOD=60            # Days of historical data
CONFIDENCE_THRESHOLD=0.65     # Minimum confidence for signal

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/predictor.log
